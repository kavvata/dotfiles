{
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ن¸€",
      "2": "مپ«",
      "3": "ن¸‰",
      "4": "ه››",
      "5": "ن؛”",
      "6": "ه…­",
      "7": "ن¸ƒ",
      "8": "ه…«",
      "9": "ن¹‌",
      "10": "هچپ",
      "urgent": "ïپھ",
      "default": "ï„‘",
    },
    "sort-by-number": true,
  },
  "niri/window": {
    "format": "{app_id}",
  },
  "niri/workspaces": {
    "on-click": "activate",
    "on-scroll-up": "niri msg action focus-workspace-up",
    "on-scroll-down": "niri msg action focus-workspace-down",
    "active-only": false,
    "all-outputs": false,
    "format": "{icon}",
    "format-icons": {
      "1": "ن¸€",
      "2": "مپ«",
      "3": "ن¸‰",
      "4": "ه››",
      "5": "ن؛”",
      "6": "ه…­",
      "7": "ن¸ƒ",
      "8": "ه…«",
      "9": "ن¹‌",
      "10": "هچپ",
      "urgent": "ïپھ",
      "default": "ï„‘",
    },
    "sort-by-number": true,
  },
  "sway/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ن¸€",
      "2": "مپ«",
      "3": "ن¸‰",
      "4": "ه››",
      "5": "ن؛”",
      "6": "ه…­",
      "7": "ن¸ƒ",
      "8": "ه…«",
      "9": "ن¹‌",
      "10": "هچپ",
      "urgent": "ïپھ",
      "default": "ï„‘",
    },
    "sort-by-number": true,
  },
  "custom/appmenu": {
    "format": "ïŒ“ ",
    "on-click": "vicinae toggle",
    "tooltip": false,
  },
  "custom/exit": {
    "format": "ï€‘  ",
    "on-click": "bash /home/kav/.config/rofi/scripts/powermenu_t1",
  },
  "custom/wofi-exit": {
    "format": "ï€‘ ",
    "on-click": "/home/kav/.config/kav-scripts/power-menu.sh",
  },
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "ï€£",
      "unlocked": "ï‚œ",
    },
  },
  "tray": {
    "spacing": 10,
  },
  "clock": {
    "tooltip": false,
    "format": "{:%a, %H:%M â€¢ %b %d}",
    "on-double-click": "exec xdg-open https://calendar.google.com/",
  },
  "custom/system": {
    "format": "î‘³ ",
    "tooltip": false,
  },
  "cpu": {
    "format": "ï’¼  {usage}%",
    "on-double-click": "kitty -e btop",
  },
  "memory": {
    "format": "î؟…  {}%",
    "on-double-click": "kitty -e btop",
  },
  "disk": {
    "interval": 30,
    "format": " ï‡€ {percentage_used}%",
    "path": "/",
    "on-click": "kitty -e btop",
  },
  "hyprland/language": {
    "format": "/ K {short}",
  },
  "network": {
    "format-wifi": "{icon}",
    "tooltip-format": "{essid} - {frequency}G ({signalStrength}%)",
    "format-ethernet": "{ifname} ïƒپ",
    "format-disconnected": "ïƒپ ",
    "max-length": 50,
    "on-double-click": "vicinae deeplink vicinae://extensions/dagimg-dot/wifi-commander/scan-wifi",
    "format-icons": [
      "َ°¤¯ ",
      "َ°¤ں ",
      "َ°¤¢ ",
      "َ°¤¥ ",
      "َ°¤¨ "
    ],
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "ï—§  {capacity}%",
    "format-plugged": "ï‡¦  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": [
      "ï‰„ ",
      "ï‰ƒ ",
      "ï‰‚ ",
      "ï‰پ ",
      "ï‰€ "
    ],
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": "{icon}",
    "format-bluetooth-muted": "î¬¤ ",
    "format-muted": "î¬¤",
    "format-source": "{volume}% ï„°",
    "format-source-muted": "ï„±",
    "format-icons": {
      "headphone": "ï€¥",
      "hands-free": "ï€¥",
      "headset": "ï€¥",
      "default": [
        "ï€¦",
        "ï€§",
        "ï€¨"
      ],
    },
    "on-double-click": "pavucontrol",
    "scroll-step": 5,
  },
  "bluetooth": {
    "format": "َ°‚¯",
    "format-connected-battery": "َ°‚¯{icon}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "",
    "format-no-controller": "",
    "format-icons": [
      "َ°¤¾ ",
      "َ°¥€ ",
      "َ°¥‚ ",
      "َ°¥„ ",
      "َ°¥† "
    ]
  },
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false,
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "َ°…¶ ",
      "deactivated": "َ°¾ھ ",
    },
    "on-click-right": "hyprlock",
  },
  "battery#ext": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "bat": "BAT0",
    "format": "{capacity}% {icon} ",
    "format-charging": "{capacity}% ï€،",
    "format-plugged": "{capacity}% ï‡¦",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ï‰„",
      "ï‰ƒ",
      "ï‰‚",
      "ï‰پ",
      "ï‰€"
    ],
  },
  "battery#int": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "bat": "BAT1",
    "format": "{icon}  {capacity}%",
    "format-charging": "ï€،  {capacity}%",
    "format-plugged": "ï‡¦  {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": [
      "ï‰„ ",
      "ï‰ƒ ",
      "ï‰‚ ",
      "ï‰پ ",
      "ï‰€ "
    ],
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "َ°ƒ‍",
      "َ°ƒ‌",
      "َ°ƒں",
      "َ°ƒ "
    ],
    "scroll-step": 5,
  },
  "custom/vpn": {
    "interval": 3,
    "format": "{}",
    "exec": "ip add show | grep -qF tap0 && echo 'َ°¦‌ '",
    "max-length": "100",
  },
  "group/batteries": {
    "orientation": "inherit",
    "modules": [
      "battery#ext",
      "battery#int"
    ],
  },
  "group/power": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false,
    },
    "modules": [
      "group/batteries",
      "backlight"
    ],
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false,
    },
    "modules": [
      "idle_inhibitor",
      "disk",
      "memory",
      "cpu",
      "tray"
    ],
  },
  "group/misc": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false,
    },
    "modules": [
      "idle_inhibitor",
      "tray"
    ],
  },
  "group/networks": {
    "orientation": "inherit",
    "modules": [
      "network",
      "custom/vpn",
      "bluetooth"
    ],
  },
}
