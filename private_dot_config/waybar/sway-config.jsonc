{
  "include": [
    "~/.config/waybar/modules.jsonc"
  ],
  "modules-left": [
    "custom/appmenu",
    "sway/window"
  ],
  "modules-center": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-right": [
    "group/misc",
    "pulseaudio",
    "pulseaudio/slider",
    "backlight",
    "backlight/slider",
    "group/networks",
    "group/batteries",
    "clock"
  ]
}
